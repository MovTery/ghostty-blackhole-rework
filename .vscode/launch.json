{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug (F5)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/blackhole.exe",
            "args": [],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "build-debug",
